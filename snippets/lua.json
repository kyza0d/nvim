{
  "Lua table": {
    "prefix": "lt",
    "body": ["local $1 = {$2}"],
    "description": "Snippet to create a Lua table"
  },
  "Print": {
    "prefix": "p",
    "body": ["print($1)"],
    "description": "Snippet to print"
  },
  "Metatable": {
    "prefix": "mt",
    "body": ["setmetatable($1, $2)"],
    "description": "Snippet to create a metatable"
  }
}
