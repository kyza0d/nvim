{
  "name": "nvim-snippets",
  "author": "nvim",
  "engines": {
    "vscode": "^1.11.0"
  },
  "contributes": {
    "snippets": [
      {
        "language": [
          "global",
          "all"
        ],
        "path": "./global.json"
      },
      {
        "language": [
          "markdown",
          "txt"
        ],
        "path": "./markdown.json"
      },
      {
        "language": "html",
        "path": "./html.json"
      },
      {
        "language": [
          "typescript",
          "typescriptreact"
        ],
        "path": "./typescript.json"
      },
      {
        "language": [
          "javascript",
          "javascriptreact"
        ],
        "path": "./javascript.json"
      },
      {
        "language": "lua",
        "path": "./lua.json"
      }
    ]
  }
}
