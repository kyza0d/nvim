{
  "name": "nvim-snippets",
  "author": "nvim",
  "engines": {
    "vscode": "^1.11.0"
  },
  "contributes": {
    "snippets": [
      {
        "language": [
          "plaintext",
          "markdown",
          "tex",
          "html",
          "global",
          "all"
        ],
        "path": "global.json"
      },
      {
        "language": [
          "typescript",
          "typescriptreact"
        ],
        "path": "react.json"
      },
      {
        "language": [
          "markdown"
        ],
        "path": "markdown.json"
      },
      {
        "language": [
          "typescript",
          "typescriptreact"
        ],
        "path": "typescript.json"
      },
      {
        "language": "lua",
        "path": "lua.json"
      }
    ]
  }
}
